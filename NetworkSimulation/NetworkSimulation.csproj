<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net48</TargetFramework>
    <RootNamespace>NetworkSimulation</RootNamespace>
    <AssemblyName>NetworkSimulation</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <AutoGenerateBindingRedirects>true</AutoGenerateBindingRedirects>
    <GenerateBindingRedirectsOutputType>true</GenerateBindingRedirectsOutputType>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="NetworkSimulation.Tests\**\*.cs" />
    <EmbeddedResource Remove="NetworkSimulation.Tests\**\*" />
    <None Remove="NetworkSimulation.Tests\**\*" />
  </ItemGroup>
</Project>
